      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Vision -->
        <div class="glass-card rounded-3xl p-8 md:p-10" data-aos="fade-right">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center mb-6"
               style="background:rgba(47,230,221,.1);border:1px solid rgba(47,230,221,.25)">
            <i class="fa-solid fa-eye text-xl" style="color:#2fe6dd"></i>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-4">Vision</h3>
          <p style="color:rgba(255,255,255,.62);line-height:1.8;font-size:.9rem">
            To be a globally recognised centre of excellence in VLSI Design and Technology — producing technically competent, ethically grounded, and socially responsible engineers who contribute to society through innovation.
          </p>
          <div class="mt-7 pt-5 grid grid-cols-2 gap-4" style="border-top:1px solid rgba(255,255,255,.1)">
            <div>
              <p class="font-mono text-2xl" style="color:#2fe6dd">2030</p>
              <p style="color:rgba(255,255,255,.35);font-size:.7rem;margin-top:.2rem">Global Benchmark Goal</p>
            </div>
            <div>
              <p class="font-mono text-2xl" style="color:#2fe6dd">Top 50</p>
              <p style="color:rgba(255,255,255,.35);font-size:.7rem;margin-top:.2rem">National VLSI Ranking Target</p>
            </div>
          </div>
